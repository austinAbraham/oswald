{
  "name": "@oswald-ai/oswald-core",
  "version": "0.1.2",
  "description": "Oswald the Analytical Octopus — a runtime-agnostic, MCP-native, context-rot-resistant workflow layer for analytical-engineering AI agents.",
  "type": "module",
  "license": "MIT",
  "author": "Austin Abraham",
  "homepage": "https://github.com/austinAbraham/oswald#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austinAbraham/oswald.git"
  },
  "bugs": {
    "url": "https://github.com/austinAbraham/oswald/issues"
  },
  "keywords": [
    "analytical-engineering",
    "dbt",
    "mcp",
    "ai-agents",
    "data-engineering",
    "cli",
    "workflow",
    "typescript"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "bin": {
    "oswald": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.11.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1"
  }
}
